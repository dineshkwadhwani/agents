# ============================================================
# Stock News Morning Report Agent — Environment Variables
# ============================================================
# Copy this file, rename it to .env, and fill in your values.
# Never check your actual .env file into GitHub!
# ============================================================

# ------------------------------------------------------------
# GEMINI API
# Get your key from: https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ------------------------------------------------------------
# GOOGLE OAUTH CREDENTIALS
# Get these from: https://console.cloud.google.com
# APIs & Services → Credentials → OAuth 2.0 Client IDs
# Application type: Web Application
# Redirect URI: http://localhost:5678/rest/oauth2-credential/callback
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET_HERE

# ------------------------------------------------------------
# GOOGLE DRIVE
# The ID of your stock list Excel file in Google Drive
# How to find it: Open the file in Drive, copy the ID from
# the URL: https://docs.google.com/spreadsheets/d/FILE_ID_IS_HERE/edit
# ------------------------------------------------------------
GOOGLE_DRIVE_FILE_ID=YOUR_EXCEL_FILE_ID_HERE

# ------------------------------------------------------------
# EMAIL
# The Gmail address where the morning report will be sent
# ------------------------------------------------------------
REPORT_TO_EMAIL=your@gmail.com

# ------------------------------------------------------------
# n8n SETTINGS (if self-hosting on cloud/VPS)
# Only needed if running n8n on a server, not locally
# ------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# If hosted on a domain, update to:
# N8N_HOST=yourdomain.com
# N8N_PROTOCOL=https

# ------------------------------------------------------------
# SCHEDULE (for reference only — set inside n8n workflow)
# Current schedule: Every weekday at 8:00 AM
# Cron expression: 0 8 * * 1-5
# ------------------------------------------------------------
# REPORT_SCHEDULE=0 8 * * 1-5
