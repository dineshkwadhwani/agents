# ============================================================
# Daily Weather Telegram Agent — Environment Variables
# ============================================================
# Copy this file, rename it to .env, and fill in your values.
# Never check your actual .env file into GitHub!
# ============================================================

# ------------------------------------------------------------
# OPENWEATHERMAP API
# Get your free key from: https://openweathermap.org/api
# Steps:
#   1. Sign up at https://home.openweathermap.org/users/sign_up
#   2. Go to: https://home.openweathermap.org/api_keys
#   3. Copy the default API key (or create a new one)
#   Note: New keys take up to 10 minutes to activate
# ------------------------------------------------------------
OPENWEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE

# ------------------------------------------------------------
# YOUR CITY
# The city whose weather you want to receive
# Examples: Pune, Mumbai, Delhi, Bangalore, London, Dubai
# For best accuracy use: "CityName,CountryCode" e.g. "Pune,IN"
# ------------------------------------------------------------
WEATHER_CITY=Pune,IN

# ------------------------------------------------------------
# TELEGRAM BOT TOKEN
# Get this from @BotFather on Telegram
# Steps:
#   1. Open Telegram → search for @BotFather
#   2. Send: /newbot
#   3. Give your bot a name (e.g. "My Weather Bot")
#   4. Give your bot a username (e.g. "myweather_dinesh_bot")
#   5. BotFather sends you a token — copy it here
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ------------------------------------------------------------
# TELEGRAM CHAT ID
# This is YOUR personal Telegram user ID (not the bot's)
# Steps:
#   1. Open Telegram → search for @userinfobot
#   2. Send any message to it
#   3. It replies with your Chat ID — copy the number here
# ------------------------------------------------------------
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ------------------------------------------------------------
# n8n SETTINGS (only needed if hosting on a server, not locally)
# ------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# If hosted on a domain or VPS, update to:
# N8N_HOST=yourdomain.com
# N8N_PROTOCOL=https
