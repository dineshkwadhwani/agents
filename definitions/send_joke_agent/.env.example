# ============================================================
# AI Joke Emailer Agent — Environment Variables
# ============================================================
# Copy this file, rename it to .env, and fill in your values.
# Never check your actual .env file into GitHub!
# ============================================================

# ------------------------------------------------------------
# GEMINI API
# Get your key from: https://aistudio.google.com/apikey
# Steps: Sign in → Create API key → Create in new project → Copy
# ------------------------------------------------------------
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ------------------------------------------------------------
# GOOGLE OAUTH CREDENTIALS
# Get these from: https://console.cloud.google.com
# Steps:
#   1. Create or select a project
#   2. Enable Gmail API
#   3. APIs & Services → OAuth Consent Screen → set up (External)
#   4. Add your Gmail as a Test User under Audience
#   5. APIs & Services → Credentials → Create Credentials → OAuth Client ID
#   6. Application type: Web Application
#   7. Authorised Redirect URI: http://localhost:5678/rest/oauth2-credential/callback
#   8. Copy Client ID and Client Secret below
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET_HERE

# ------------------------------------------------------------
# EMAIL
# The Gmail address that will SEND and RECEIVE the joke
# (both sender and recipient are the same for this agent)
# ------------------------------------------------------------
JOKE_TO_EMAIL=your@gmail.com

# ------------------------------------------------------------
# GEMINI MODEL (for reference — set inside n8n workflow URL)
# Current model used: gemini-2.5-flash
# Full URL in HTTP Request node:
# https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
# ------------------------------------------------------------
# GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------
# n8n SETTINGS (only needed if hosting on a server, not locally)
# ------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# If hosted on a domain or VPS, update to:
# N8N_HOST=yourdomain.com
# N8N_PROTOCOL=https
