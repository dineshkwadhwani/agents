# ============================================================
# Good Morning Telegram Agent — Environment Variables
# ============================================================
# Copy this file, rename it to .env, and fill in your values.
# Never check your actual .env file into GitHub!
# ============================================================

# ------------------------------------------------------------
# TELEGRAM BOT TOKEN
# Get this from @BotFather on Telegram
# Steps:
#   1. Open Telegram → search @BotFather
#   2. Send: /newbot
#   3. Give your bot a name (e.g. "My Morning Bot")
#   4. Give your bot a username ending in "bot" (e.g. "mymorning_yourname_bot")
#   5. BotFather sends you a token — copy it here
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ------------------------------------------------------------
# TELEGRAM CHAT ID
# Your personal Telegram user ID
# How to get it:
#   Method 1: Search @userinfobot on Telegram → send any message → copy the Id
#   Method 2: Send a message to your bot, then open in browser:
#             https://api.telegram.org/botYOUR_TOKEN/getUpdates
#             Look for "chat":{"id": YOUR_ID_HERE}
# ------------------------------------------------------------
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ------------------------------------------------------------
# SCHEDULE (for reference — set inside n8n workflow)
# Current: Every day at 8:00 AM
# Cron: 0 8 * * *
# To change to weekdays only: 0 8 * * 1-5
# ------------------------------------------------------------
# SCHEDULE=0 8 * * *

# ------------------------------------------------------------
# n8n SETTINGS (only if hosting on a server, not locally)
# ------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
