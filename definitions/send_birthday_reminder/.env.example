# ============================================================
# Birthday Reminder Telegram Bot — Environment Variables
# ============================================================
# Copy this file, rename it to .env, and fill in your values.
# Never check your actual .env file into GitHub!
# ============================================================

# ------------------------------------------------------------
# GOOGLE OAUTH CREDENTIALS
# Get these from: https://console.cloud.google.com
# Steps:
#   1. Create or select a project
#   2. Enable Google Drive API
#   3. APIs & Services → OAuth Consent Screen → set up (External)
#   4. Add your Gmail as a Test User under Audience
#   5. APIs & Services → Credentials → Create Credentials → OAuth Client ID
#   6. Application type: Web Application
#   7. Authorised Redirect URI: http://localhost:5678/rest/oauth2-credential/callback
#   8. Copy Client ID and Client Secret below
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET_HERE

# ------------------------------------------------------------
# GOOGLE DRIVE FILE
# The .xlsx file stored in Google Drive with birthday data
# Columns required: "Full Name" and "Date of Birth"
# How to find the File ID:
#   Open the file in Google Drive → copy the ID from the URL:
#   https://docs.google.com/spreadsheets/d/FILE_ID_IS_HERE/edit
# ------------------------------------------------------------
GOOGLE_DRIVE_FILE_ID=YOUR_EXCEL_FILE_ID_HERE

# ------------------------------------------------------------
# TELEGRAM BOT TOKEN
# Get this from @BotFather on Telegram
# Steps:
#   1. Open Telegram → search @BotFather
#   2. Send: /newbot
#   3. Give your bot a name (e.g. "My Birthday Bot")
#   4. Give your bot a username ending in "bot"
#   5. BotFather sends you a token — copy it here
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ------------------------------------------------------------
# TELEGRAM CHAT ID
# Your personal Telegram user ID
# How to get it:
#   Method 1: Search @userinfobot on Telegram → send any message → copy the Id
#   Method 2: Send a message to your bot, then open in browser:
#             https://api.telegram.org/botYOUR_TOKEN/getUpdates
#             Look for "chat":{"id": YOUR_ID_HERE}
# ------------------------------------------------------------
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ------------------------------------------------------------
# SCHEDULE (for reference — set inside n8n workflow)
# Current: Every day at 8:00 AM
# Cron: 0 8 * * *
# ------------------------------------------------------------
# SCHEDULE=0 8 * * *

# ------------------------------------------------------------
# n8n SETTINGS (only if hosting on a server, not locally)
# ------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
